# ========================================
# Конфигурация Telegram-бота погоды
# ========================================

# Токен бота Telegram (получить у @BotFather)
TELEGRAM_BOT_TOKEN=7123456789:AAHxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# API-ключ Яндекс.Погоды (получить на developer.tech.yandex.ru)
YANDEX_WEATHER_API_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Координаты города (по умолчанию — Москва)
CITY_LAT=55.75
CITY_LON=37.62
CITY_NAME=Москва

# Chat ID для принудительной утренней рассылки (необязательно)
# Если пусто — рассылка идёт только подписчикам через /start
MORNING_CHAT_ID=

# Время утренней рассылки (часы и минуты, МСК)
MORNING_HOUR=8
MORNING_MINUTE=0